{
  "name": "discord-economy-bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Bot Discord per economia/roleplay (banca, lavori, auto, case, negozi) con pannelli a bottoni.",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
